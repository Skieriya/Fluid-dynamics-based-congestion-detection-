# Import necessary libraries
import numpy as np
import matplotlib.pyplot as plt
import matplotlib.animation as animation
from matplotlib.patches import Rectangle, Circle
from scipy.ndimage import convolve
import cv2
from skimage import measure
from IPython.display import HTML, display
import time
import warnings
warnings.filterwarnings('ignore')

# Set random seed for reproducibility
np.random.seed(42)

class FluidTrafficSimulation:
    """
    A fluid dynamics-based traffic simulation system that models traffic as a continuous fluid
    using principles from Navier-Stokes equations.
    """

    def __init__(self, grid_size=(100, 100), dt=0.1):
        """
        Initialize the traffic fluid simulation.

        Args:
            grid_size: Tuple representing the dimensions of the simulation grid
            dt: Time step for the simulation
        """
        self.grid_size = grid_size
        self.dt = dt

        # Physical parameters for traffic fluid
        self.density = np.zeros(grid_size)  # Traffic density (vehicles per unit area)
        self.velocity_x = np.zeros(grid_size)  # Velocity in x direction
        self.velocity_y = np.zeros(grid_size)  # Velocity in y direction
        self.pressure = np.zeros(grid_size)  # Traffic pressure

        # Road network topology (1 = road, 0 = non-road)
        self.road_network = self.create_intersection()

        # Traffic light positions and states
        self.traffic_lights = self.initialize_traffic_lights()

        # Viscosity map (different for different vehicle types)
        self.base_viscosity = 0.1
        self.viscosity_map = np.ones(grid_size) * self.base_viscosity

        # Topography (height map) - affects gravity effects
        self.topography = self.create_topography()

        # Emergency vehicles (position and direction)
        self.emergency_vehicles = []

        # History for shockwave detection
        self.density_history = []
        self.history_length = 10

        # Initialize traffic
        self.initialize_traffic()

    def create_intersection(self):
        """
        Create a road network representing a four-way intersection.
        """
        road_network = np.zeros(self.grid_size)

        # Create horizontal and vertical roads
        center_x, center_y = self.grid_size[0] // 2, self.grid_size[1] // 2
        road_width = 20

        # Horizontal road
        road_network[center_x-road_width//2:center_x+road_width//2, :] = 1

        # Vertical road
        road_network[:, center_y-road_width//2:center_y+road_width//2] = 1

        return road_network

    def create_topography(self):
        """
        Create a topography map with a flyover (elevated road).
        """
        topography = np.zeros(self.grid_size)

        # Add a flyover (elevated road) in the horizontal direction
        center_x, center_y = self.grid_size[0] // 2, self.grid_size[1] // 2
        flyover_start = center_y - 30
        flyover_end = center_y + 30

        # Create a slope up and down for the flyover
        for i in range(flyover_start, center_y):
            height = 0.1 * (i - flyover_start) / (center_y - flyover_start)
            topography[center_x-10:center_x+10, i] = height

        for i in range(center_y, flyover_end):
            height = 0.1 * (flyover_end - i) / (flyover_end - center_y)
            topography[center_x-10:center_x+10, i] = height

        return topography

    def initialize_traffic_lights(self):
        """
        Initialize traffic lights at the intersection.
        """
        center_x, center_y = self.grid_size[0] // 2, self.grid_size[1] // 2
        light_distance = 25

        traffic_lights = [
            # North
            {'position': (center_x - light_distance, center_y),
             'direction': 'vertical', 'state': 'green', 'flow_threshold': 0.3},
            # South
            {'position': (center_x + light_distance, center_y),
             'direction': 'vertical', 'state': 'red', 'flow_threshold': 0.3},
            # East
            {'position': (center_x, center_y + light_distance),
             'direction': 'horizontal', 'state': 'red', 'flow_threshold': 0.3},
            # West
            {'position': (center_x, center_y - light_distance),
             'direction': 'horizontal', 'state': 'green', 'flow_threshold': 0.3}
        ]

        return traffic_lights

    def initialize_traffic(self):
        """
        Initialize traffic density and velocity based on realistic traffic patterns.
        """
        # Create initial traffic density with higher density at entry points
        center_x, center_y = self.grid_size[0] // 2, self.grid_size[1] // 2

        # Entry points for traffic
        entry_points = [
            (center_x, 10),  # West entry
            (center_x, self.grid_size[1] - 10),  # East entry
            (10, center_y),  # North entry
            (self.grid_size[0] - 10, center_y)  # South entry
        ]

        # Initialize density with random traffic at entry points
        for x, y in entry_points:
            # Create a Gaussian distribution of traffic around each entry point
            for i in range(max(0, x-15), min(self.grid_size[0], x+15)):
                for j in range(max(0, y-15), min(self.grid_size[1], y+15)):
                    if self.road_network[i, j] == 1:
                        dist = np.sqrt((i-x)**2 + (j-y)**2)
                        self.density[i, j] = 0.5 * np.exp(-dist**2 / 50) + np.random.uniform(0, 0.2)

        # Initialize velocity based on road direction
        # Horizontal roads (left to right)
        self.velocity_x[center_x-10:center_x+10, :center_y-20] = 1.0
        self.velocity_x[center_x-10:center_x+10, center_y+20:] = 1.0

        # Vertical roads (top to bottom)
        self.velocity_y[:center_x-20, center_y-10:center_y+10] = 1.0
        self.velocity_y[center_x+20:, center_y-10:center_y+10] = 1.0

        # Add some randomness to velocity
        self.velocity_x += np.random.uniform(-0.1, 0.1, self.grid_size)
        self.velocity_y += np.random.uniform(-0.1, 0.1, self.grid_size)

        # Ensure velocity is zero outside of roads
        self.velocity_x *= self.road_network
        self.velocity_y *= self.road_network

    def calculate_reynolds_number(self):
        """
        Calculate the Reynolds number for traffic flow at each point.
        Re = (density * velocity * characteristic_length) / viscosity

        Returns:
            Array of Reynolds numbers
        """
        # Calculate velocity magnitude
        velocity_magnitude = np.sqrt(self.velocity_x**2 + self.velocity_y**2)

        # Characteristic length (in this case, we'll use a fixed value related to grid size)
        characteristic_length = 1.0

        # Calculate Reynolds number
        reynolds = (self.density * velocity_magnitude * characteristic_length) / self.viscosity_map

        # Handle division by zero
        reynolds = np.nan_to_num(reynolds)

        return reynolds

    def update_traffic_lights(self):
        """
        Update traffic light states based on flow metrics (timer-less logic).
        """
        reynolds = self.calculate_reynolds_number()

        for light in self.traffic_lights:
            x, y = light['position']

            # Get flow metrics around the traffic light
            if light['direction'] == 'horizontal':
                # For horizontal lights, check flow in x direction
                flow_region = self.velocity_x[max(0, x-5):min(self.grid_size[0], x+5),
                                              max(0, y-5):min(self.grid_size[1], y+5)]
            else:
                # For vertical lights, check flow in y direction
                flow_region = self.velocity_y[max(0, x-5):min(self.grid_size[0], x+5),
                                              max(0, y-5):min(self.grid_size[1], y+5)]

            # Calculate average flow
            avg_flow = np.mean(np.abs(flow_region))

            # Calculate local Reynolds number
            local_reynolds = np.mean(reynolds[max(0, x-5):min(self.grid_size[0], x+5),
                                             max(0, y-5):min(self.grid_size[1], y+5)])

            # Timer-less logic: change light based on flow threshold and Reynolds number
            if light['state'] == 'green':
                # If flow drops below threshold or Reynolds number indicates turbulence, change to red
                if avg_flow < light['flow_threshold'] or local_reynolds > 2000:
                    light['state'] = 'red'
            else:  # red
                # If flow builds up and Reynolds number is stable, change to green
                if avg_flow > light['flow_threshold'] * 1.5 and local_reynolds < 1500:
                    light['state'] = 'green'

    def detect_shockwaves(self):
        """
        Detect shockwaves in traffic flow (sudden changes in density).

        Returns:
            List of shockwave positions
        """
        # Store current density in history
        self.density_history.append(self.density.copy())
        if len(self.density_history) > self.history_length:
            self.density_history.pop(0)

        shockwaves = []

        if len(self.density_history) >= 3:
            # Calculate density gradient over time
            density_gradient = np.zeros(self.grid_size)

            for i in range(1, len(self.density_history)):
                density_gradient += np.abs(self.density_history[i] - self.density_history[i-1])

            # Normalize
            density_gradient /= len(self.density_history) - 1

            # Find areas with high gradient (potential shockwaves)
            threshold = np.percentile(density_gradient[self.road_network == 1], 90)
            shockwave_mask = (density_gradient > threshold) & (self.road_network == 1)

            # Find connected components (shockwave regions)
            labeled, num_features = measure.label(shockwave_mask, return_num=True)

            for i in range(1, num_features + 1):
                coords = np.where(labeled == i)
                if len(coords[0]) > 0:
                    # Calculate center of mass
                    center_x = np.mean(coords[0])
                    center_y = np.mean(coords[1])
                    shockwaves.append((center_x, center_y))

        return shockwaves

    def create_emergency_rarefaction(self, start_pos, end_pos):
        """
        Create a rarefaction wave (low-density region) to clear a path for emergency vehicles.

        Args:
            start_pos: Starting position of the emergency vehicle
            end_pos: Destination of the emergency vehicle
        """
        # Calculate direction vector
        dx = end_pos[0] - start_pos[0]
        dy = end_pos[1] - start_pos[1]
        length = np.sqrt(dx**2 + dy**2)

        if length > 0:
            dx /= length
            dy /= length

            # Create a path of reduced density
            steps = int(length)
            for i in range(steps):
                x = int(start_pos[0] + i * dx)
                y = int(start_pos[1] + i * dy)

                # Reduce density in a region around the path
                for j in range(max(0, x-3), min(self.grid_size[0], x+4)):
                    for k in range(max(0, y-3), min(self.grid_size[1], y+4)):
                        dist = np.sqrt((j-x)**2 + (k-y)**2)
                        if dist < 3 and self.road_network[j, k] == 1:
                            # Create a rarefaction wave (reduce density)
                            self.density[j, k] *= 0.5

                            # Adjust velocity to direct traffic away from the path
                            if j != x or k != y:
                                # Calculate vector away from path
                                away_x = j - x
                                away_y = k - y
                                away_length = np.sqrt(away_x**2 + away_y**2)

                                if away_length > 0:
                                    away_x /= away_length
                                    away_y /= away_length

                                    # Increase velocity away from the path
                                    self.velocity_x[j, k] += 0.5 * away_x
                                    self.velocity_y[j, k] += 0.5 * away_y

    def update_emergency_vehicles(self):
        """
        Update positions of emergency vehicles and create rarefaction waves.
        """
        new_emergency_vehicles = []

        for vehicle in self.emergency_vehicles:
            x, y, dest_x, dest_y = vehicle

            # Calculate direction to destination
            dx = dest_x - x
            dy = dest_y - y
            length = np.sqrt(dx**2 + dy**2)

            if length > 1:
                # Normalize direction
                dx /= length
                dy /= length

                # Update position
                new_x = x + dx * 2  # Emergency vehicles move faster
                new_y = y + dy * 2

                # Create rarefaction wave ahead of the vehicle
                self.create_emergency_rarefaction((int(new_x), int(new_y)), (dest_x, dest_y))

                # Keep vehicle if not at destination
                new_emergency_vehicles.append((new_x, new_y, dest_x, dest_y))

        self.emergency_vehicles = new_emergency_vehicles

    def add_emergency_vehicle(self, start_pos, end_pos):
        """
        Add an emergency vehicle to the simulation.

        Args:
            start_pos: Starting position (x, y)
            end_pos: Destination position (x, y)
        """
        self.emergency_vehicles.append((start_pos[0], start_pos[1], end_pos[0], end_pos[1]))

    def update(self):
        """
        Update the traffic simulation using fluid dynamics principles.
        """
        # Store old values
        old_density = self.density.copy()
        old_velocity_x = self.velocity_x.copy()
        old_velocity_y = self.velocity_y.copy()

        # Calculate divergence of velocity
        div_velocity = np.zeros(self.grid_size)
        div_velocity[1:-1, 1:-1] = (
            (old_velocity_x[1:-1, 2:] - old_velocity_x[1:-1, :-2]) / 2 +
            (old_velocity_y[2:, 1:-1] - old_velocity_y[:-2, 1:-1]) / 2
        )

        # Update pressure (simplified pressure Poisson equation)
        self.pressure = np.zeros(self.grid_size)
        for _ in range(20):  # Iterative solver
            self.pressure[1:-1, 1:-1] = 0.25 * (
                self.pressure[1:-1, 2:] + self.pressure[1:-1, :-2] +
                self.pressure[2:, 1:-1] + self.pressure[:-2, 1:-1] -
                div_velocity[1:-1, 1:-1]
            )

        # Calculate pressure gradient
        grad_pressure_x = np.zeros(self.grid_size)
        grad_pressure_y = np.zeros(self.grid_size)
        grad_pressure_x[:, 1:-1] = (self.pressure[:, 2:] - self.pressure[:, :-2]) / 2
        grad_pressure_y[1:-1, :] = (self.pressure[2:, :] - self.pressure[:-2, :]) / 2

        # Calculate gravity effect based on topography
        grad_topography_x = np.zeros(self.grid_size)
        grad_topography_y = np.zeros(self.grid_size)
        grad_topography_x[:, 1:-1] = (self.topography[:, 2:] - self.topography[:, :-2]) / 2
        grad_topography_y[1:-1, :] = (self.topography[2:, :] - self.topography[:-2, :]) / 2

        gravity_x = -9.8 * grad_topography_x * 0.01  # Scaled gravity effect
        gravity_y = -9.8 * grad_topography_y * 0.01  # Scaled gravity effect

        # Calculate Laplacian of velocity (diffusion term)
        laplacian_vx = np.zeros(self.grid_size)
        laplacian_vy = np.zeros(self.grid_size)
        laplacian_vx[1:-1, 1:-1] = (
            old_velocity_x[1:-1, 2:] + old_velocity_x[1:-1, :-2] +
            old_velocity_x[2:, 1:-1] + old_velocity_x[:-2, 1:-1] -
            4 * old_velocity_x[1:-1, 1:-1]
        )
        laplacian_vy[1:-1, 1:-1] = (
            old_velocity_y[1:-1, 2:] + old_velocity_y[1:-1, :-2] +
            old_velocity_y[2:, 1:-1] + old_velocity_y[:-2, 1:-1] -
            4 * old_velocity_y[1:-1, 1:-1]
        )

        # Update velocity (Navier-Stokes equation)
        self.velocity_x = old_velocity_x + self.dt * (
            -old_velocity_x * np.gradient(old_velocity_x, axis=0) -
            old_velocity_y * np.gradient(old_velocity_x, axis=1) -
            grad_pressure_x / (old_density + 0.1) +  # Avoid division by zero
            self.viscosity_map * laplacian_vx +
            gravity_x
        )

        self.velocity_y = old_velocity_y + self.dt * (
            -old_velocity_x * np.gradient(old_velocity_y, axis=0) -
            old_velocity_y * np.gradient(old_velocity_y, axis=1) -
            grad_pressure_y / (old_density + 0.1) +  # Avoid division by zero
            self.viscosity_map * laplacian_vy +
            gravity_y
        )

        # Update density (continuity equation)
        self.density = old_density - self.dt * (
            np.gradient(old_density * old_velocity_x, axis=0) +
            np.gradient(old_density * old_velocity_y, axis=1)
        )

        # Apply boundary conditions (no-slip at non-road boundaries)
        self.velocity_x *= self.road_network
        self.velocity_y *= self.road_network
        self.density *= self.road_network

        # Ensure density stays within physical bounds
        self.density = np.clip(self.density, 0, 1)

        # Limit maximum velocity
        velocity_magnitude = np.sqrt(self.velocity_x**2 + self.velocity_y**2)
        max_velocity = 2.0
        mask = velocity_magnitude > max_velocity
        self.velocity_x[mask] *= max_velocity / velocity_magnitude[mask]
        self.velocity_y[mask] *= max_velocity / velocity_magnitude[mask]

        # Update traffic lights
        self.update_traffic_lights()

        # Apply traffic light effects
        for light in self.traffic_lights:
            x, y = light['position']

            if light['state'] == 'red':
                # Create a barrier at the traffic light
                if light['direction'] == 'horizontal':
                    # Stop horizontal flow
                    self.velocity_x[max(0, x-2):min(self.grid_size[0], x+3),
                                   max(0, y-1):min(self.grid_size[1], y+2)] = 0
                else:
                    # Stop vertical flow
                    self.velocity_y[max(0, x-1):min(self.grid_size[0], x+2),
                                   max(0, y-2):min(self.grid_size[1], y+3)] = 0

        # Detect shockwaves
        shockwaves = self.detect_shockwaves()

        # Update emergency vehicles
        self.update_emergency_vehicles()

        # Occasionally add new traffic at entry points
        if np.random.random() < 0.1:
            self.add_random_traffic()

        return shockwaves

    def add_random_traffic(self):
        """
        Add random traffic at entry points.
        """
        center_x, center_y = self.grid_size[0] // 2, self.grid_size[1] // 2

        # Entry points for traffic
        entry_points = [
            (center_x, 10),  # West entry
            (center_x, self.grid_size[1] - 10),  # East entry
            (10, center_y),  # North entry
            (self.grid_size[0] - 10, center_y)  # South entry
        ]

        # Randomly select an entry point
        x, y = entry_points[np.random.randint(0, len(entry_points))]

        # Add traffic density
        for i in range(max(0, x-10), min(self.grid_size[0], x+10)):
            for j in range(max(0, y-10), min(self.grid_size[1], y+10)):
                if self.road_network[i, j] == 1:
                    self.density[i, j] = min(1.0, self.density[i, j] + np.random.uniform(0.1, 0.3))

    def visualize(self, shockwaves=None):
        """
        Visualize the current state of the traffic simulation.

        Args:
            shockwaves: List of shockwave positions to highlight
        """
        fig, axes = plt.subplots(2, 2, figsize=(15, 12))

        # Plot 1: Traffic density
        ax1 = axes[0, 0]
        density_plot = ax1.imshow(self.density, cmap='YlOrRd', vmin=0, vmax=1)
        ax1.set_title('Traffic Density')
        plt.colorbar(density_plot, ax=ax1, label='Density')

        # Plot road network outline
        road_outline = np.zeros_like(self.road_network)
        road_outline[1:-1, 1:-1] = (
            (self.road_network[1:-1, 1:-1] != self.road_network[:-2, 1:-1]) |
            (self.road_network[1:-1, 1:-1] != self.road_network[2:, 1:-1]) |
            (self.road_network[1:-1, 1:-1] != self.road_network[1:-1, :-2]) |
            (self.road_network[1:-1, 1:-1] != self.road_network[1:-1, 2:])
        )
        ax1.contour(road_outline, levels=[0.5], colors='black', linewidths=1)

        # Plot traffic lights
        for light in self.traffic_lights:
            x, y = light['position']
            color = 'green' if light['state'] == 'green' else 'red'
            ax1.add_patch(Circle((y, x), 2, color=color))

        # Plot emergency vehicles
        for vehicle in self.emergency_vehicles:
            x, y, _, _ = vehicle
            ax1.add_patch(Circle((y, x), 3, color='blue'))

        # Plot shockwaves
        if shockwaves:
            for x, y in shockwaves:
                ax1.add_patch(Circle((y, x), 5, color='purple', fill=False, linewidth=2))

        # Plot 2: Velocity field
        ax2 = axes[0, 1]
        velocity_magnitude = np.sqrt(self.velocity_x**2 + self.velocity_y**2)
        velocity_plot = ax2.imshow(velocity_magnitude, cmap='viridis', vmin=0, vmax=2)
        ax2.set_title('Velocity Magnitude')
        plt.colorbar(velocity_plot, ax=ax2, label='Velocity')

        # Add velocity vectors (quiver plot)
        step = 5
        x, y = np.meshgrid(np.arange(0, self.grid_size[1], step),
                          np.arange(0, self.grid_size[0], step))
        ax2.quiver(x, y,
                  self.velocity_x[::step, ::step],
                  self.velocity_y[::step, ::step],
                  color='white', alpha=0.7)

        # Plot road network outline
        ax2.contour(road_outline, levels=[0.5], colors='black', linewidths=1)

        # Plot 3: Reynolds number
        ax3 = axes[1, 0]
        reynolds = self.calculate_reynolds_number()
        reynolds_plot = ax3.imshow(reynolds, cmap='plasma', vmin=0, vmax=2000)
        ax3.set_title('Reynolds Number (Flow Characteristic)')
        plt.colorbar(reynolds_plot, ax=ax3, label='Re')

        # Plot road network outline
        ax3.contour(road_outline, levels=[0.5], colors='black', linewidths=1)

        # Plot 4: Topography
        ax4 = axes[1, 1]
        topography_plot = ax4.imshow(self.topography, cmap='terrain')
        ax4.set_title('Topography (Elevation)')
        plt.colorbar(topography_plot, ax=ax4, label='Height')

        # Plot road network outline
        ax4.contour(road_outline, levels=[0.5], colors='black', linewidths=1)

        plt.tight_layout()
        plt.show()

    def run_simulation(self, steps=100, visualize_every=10):
        """
        Run the traffic simulation for a specified number of steps.

        Args:
            steps: Number of simulation steps
            visualize_every: How often to visualize the simulation
        """
        for step in range(steps):
            # Update simulation
            shockwaves = self.update()

            # Visualize at specified intervals
            if step % visualize_every == 0:
                print(f"Step {step}/{steps}")
                self.visualize(shockwaves)

                # Print statistics
                avg_density = np.mean(self.density[self.road_network == 1])
                avg_velocity = np.mean(np.sqrt(self.velocity_x**2 + self.velocity_y**2)[self.road_network == 1])
                avg_reynolds = np.mean(self.calculate_reynolds_number()[self.road_network == 1])

                print(f"Average Density: {avg_density:.3f}")
                print(f"Average Velocity: {avg_velocity:.3f}")
                print(f"Average Reynolds Number: {avg_reynolds:.1f}")
                print(f"Number of Shockwaves Detected: {len(shockwaves)}")
                print(f"Number of Emergency Vehicles: {len(self.emergency_vehicles)}")
                print("-" * 40)

                # Add an emergency vehicle occasionally
                if step == 30:
                    center_x, center_y = self.grid_size[0] // 2, self.grid_size[1] // 2
                    self.add_emergency_vehicle((10, center_y), (center_x, self.grid_size[1] - 10))
                    print("Emergency vehicle added!")

                time.sleep(0.5)  # Pause for visualization

